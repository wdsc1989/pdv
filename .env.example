# Copie para .env e preencha os valores.
# Nunca commite o arquivo .env (já está no .gitignore).

# --- Obrigatório em produção (PostgreSQL) ---
# DATABASE_URL=postgresql://usuario:senha@host:5432/pdv_db

# --- Opcional: forçar configuração de IA via ambiente ---
# Se AI_FIXED_CONFIG_ENABLED=true, o app usa as variáveis abaixo em vez da tela Administração.
# AI_FIXED_PROVIDER=openai
# AI_FIXED_MODEL=gpt-4o
# AI_FIXED_API_KEY=sk-...

# --- Desenvolvimento ---
# Se DATABASE_URL não for definido, o app usa SQLite em data/pdv.db
